---
const actions = [
  { label: 'Get Started', href: '/toon-memory/getting-started/quickstart', primary: true },
  { label: 'View on GitHub', href: 'https://github.com/LuiggiVal08/toon-memory', primary: false },
];
---

<section class="content-section cta-section">
  <div class="cta-box">
    <h2>Ready to give your agent a memory?</h2>
    <p>Install in seconds and never re-explain context to your agent again.</p>
    <div class="cta-actions">
      {
        actions.map((a) => (
          <a
            href={a.href}
            class:list={['btn', a.primary ? 'btn-primary' : 'btn-github']}
            target={a.primary ? undefined : '_blank'}
            rel={a.primary ? undefined : 'noopener noreferrer'}
          >
            {a.label}
          </a>
        ))
      }
    </div>
  </div>
</section>

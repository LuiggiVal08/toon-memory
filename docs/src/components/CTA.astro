---
import { getContent } from '../i18n';

interface Props {
	lang?: string;
}
const { lang = 'en' } = Astro.props;
const c = getContent(lang);

const actions = [
  { label: c.cta.getStarted, href: lang === 'es' ? '/toon-memory/es/getting-started/quickstart' : '/toon-memory/getting-started/quickstart', primary: true },
  { label: c.cta.viewGithub, href: 'https://github.com/LuiggiVal08/toon-memory', primary: false },
];
---

<section class="content-section cta-section">
  <div class="cta-box">
    <h2>{c.cta.title}</h2>
    <p>{c.cta.subtitle}</p>
    <div class="cta-actions">
      {
        actions.map((a) => (
          <a
            href={a.href}
            class:list={['btn', a.primary ? 'btn-primary' : 'btn-github']}
            target={a.primary ? undefined : '_blank'}
            rel={a.primary ? undefined : 'noopener noreferrer'}
          >
            {a.label}
          </a>
        ))
      }
    </div>
  </div>
</section>

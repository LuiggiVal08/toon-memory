---
import { getContent } from '../i18n';

interface Props {
	lang?: string;
}
const { lang = 'en' } = Astro.props;
const c = getContent(lang);
---

<section class="content-section faq-section">
  <div class="section-header">
    <h2>{c.faq.title}</h2>
    <p>{c.faq.subtitle}</p>
  </div>

  <div class="faq-list">
    {
      c.faq.items.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p set:html={f.a}></p>
        </details>
      ))
    }
  </div>
</section>

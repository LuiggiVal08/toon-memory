---
import { getContent } from '../i18n';

interface Props {
	lang?: string;
}
const { lang = 'en' } = Astro.props;
const c = getContent(lang);
---

<section class="content-section">
  <div class="section-header">
    <h2>{c.codeExamples.quickExample}</h2>
  </div>
  <pre><code set:html={c.codeExamples.exampleCode}></code></pre>

  <div class="section-header">
    <h2>{c.codeExamples.quickInstall}</h2>
  </div>
  <pre><code set:html={c.codeExamples.installCode}></code></pre>
</section>

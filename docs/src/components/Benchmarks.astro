---
import { getContent } from '../i18n';

interface Props {
	lang?: string;
}
const { lang = 'en' } = Astro.props;
const c = getContent(lang);

const jsonTokens = 1097;
const toonTokens = 850;
const reductionPct = 22.5;
const singleReductionPct = 30.5;
const entries = 16;

const rows = [
  { format: 'JSON', tokens: jsonTokens, cls: 'bar-json' },
  { format: 'TOON', tokens: toonTokens, cls: 'bar-toon' },
];
---

<section class="content-section benchmarks-section">
  <div class="section-header">
    <h2>{c.benchmarks.title}</h2>
    <p>{c.benchmarks.subtitle}</p>
  </div>

  <div class="savings-bars">
    {
      rows.map((r) => (
        <div class="savings-bar">
          <span class="savings-label">{r.format}</span>
          <div class="bar-track">
            <div class={`bar ${r.cls}`} style={`width:${(r.tokens / jsonTokens) * 100}%`}>
              <span>{r.tokens}</span>
            </div>
          </div>
        </div>
      ))
    }
  </div>

  <div class="savings-stats">
    <div class="savings-stat">
      <span class="savings-num">{reductionPct}%</span>
      <span class="savings-cap">{c.benchmarks.fewerTokens}</span>
    </div>
    <div class="savings-stat">
      <span class="savings-num">{singleReductionPct}%</span>
      <span class="savings-cap">{c.benchmarks.onSingle}</span>
    </div>
    <div class="savings-stat">
      <span class="savings-num">{entries}</span>
      <span class="savings-cap">{c.benchmarks.entriesMeasured}</span>
    </div>
  </div>

  <p class="savings-note" set:html={c.benchmarks.note}></p>
</section>

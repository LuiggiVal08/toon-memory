---
import { getContent } from '../i18n';

interface Props {
	lang?: string;
}
const { lang = 'en' } = Astro.props;
const c = getContent(lang);
---

<section class="content-section">
  <div class="section-header">
    <h2>{c.comparison.title}</h2>
    <p>{c.comparison.subtitle}</p>
  </div>

  <div class="comparison">
    <div class="compare-box before">
      <h3>{c.comparison.beforeTitle}</h3>
      <ul>
        {c.comparison.before.map((item) => <li>{item}</li>)}
      </ul>
    </div>
    <div class="compare-box after">
      <h3>{c.comparison.afterTitle}</h3>
      <ul>
        {c.comparison.after.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </div>
</section>

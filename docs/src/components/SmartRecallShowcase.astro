---
import { getContent } from '../i18n';

interface Props {
	lang?: string;
}
const { lang = 'en' } = Astro.props;
const c = getContent(lang);
const s = c.smartRecallSection;
---

<section class="content-section smart-recall">
	<div class="section-header">
		<h2>{s.title}</h2>
		<p>{s.subtitle}</p>
	</div>

	<div class="recall-grid">
		<div class="recall-points">
			<ul>
				{s.points.map((p: string) => <li set:html={p} />)}
			</ul>
		</div>

		<div class="recall-examples">
			<div class="recall-col">
				<span class="recall-tag">standard</span>
				<pre class="code-block"><code>{s.standardCode}</code></pre>
			</div>
			<div class="recall-col compact-col">
				<span class="recall-tag">compact: true</span>
				<pre class="code-block"><code>{s.compactCode}</code></pre>
			</div>
		</div>
	</div>

	<p class="recall-caption">{s.caption}</p>
</section>

<script>
	import { revealOnView } from '../scripts/home-anim';
	const root = document.querySelector<HTMLElement>('.smart-recall');
	if (root) revealOnView(root, 'in-view');
</script>

<style>
	.smart-recall {
		background: var(--surface-2, #0f1420);
	}
	.recall-grid {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 2rem;
		align-items: stretch;
	}
	.recall-points {
		display: flex;
	}
	.recall-points ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
	}
	.recall-points li {
		position: relative;
		padding-left: 1.4rem;
		color: var(--text-muted, #aab);
		line-height: 1.5;
	}
	.recall-points li::before {
		content: '▸';
		position: absolute;
		left: 0;
		color: var(--accent, #6cf);
	}
	.recall-examples {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		align-items: stretch;
	}
	.recall-col {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		height: 100%;
	}
	.recall-tag {
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted, #889);
		min-height: 1rem;
	}
	.compact-col .recall-tag {
		color: var(--accent, #6cf);
	}
	.code-block {
		margin: 0;
		font-size: 0.8rem;
		line-height: 1.5;
		background: #0b0f18;
		border: 1px solid var(--border, #1d2533);
		border-radius: 10px;
		padding: 0.9rem 1rem;
		overflow-x: auto;
		white-space: pre-wrap;
		word-break: break-word;
	}
	.recall-col .code-block {
		flex: 1;
	}
	.compact-col .code-block {
		border-color: color-mix(in srgb, var(--accent, #6cf) 40%, transparent);
	}
	.recall-caption {
		margin-top: 1.5rem;
		color: var(--text-muted, #889);
		font-size: 0.92rem;
	}
	@media (max-width: 820px) {
		.recall-grid {
			grid-template-columns: 1fr;
		}
		.recall-examples {
			grid-template-columns: 1fr;
		}
	}
</style>

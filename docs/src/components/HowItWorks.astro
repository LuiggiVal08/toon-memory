---
import { getContent } from '../i18n';

interface Props {
	lang?: string;
}
const { lang = 'en' } = Astro.props;
const c = getContent(lang);
---

<section class="content-section how-section">
  <div class="section-header">
    <h2>{c.howItWorks.title}</h2>
    <p>{c.howItWorks.subtitle}</p>
  </div>

  <div class="steps">
    {
      c.howItWorks.steps.map((s) => (
        <div class="step">
          <div class="step-num">{s.n}</div>
          <h3>{s.title}</h3>
          <p>{s.body}</p>
          <pre><code set:html={s.code}></code></pre>
        </div>
      ))
    }
  </div>
</section>

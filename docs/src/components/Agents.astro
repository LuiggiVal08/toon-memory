---
import { getContent } from '../i18n';

interface Props {
	lang?: string;
}
const { lang = 'en' } = Astro.props;
const c = getContent(lang);
---

<section class="content-section agents-section">
  <div class="section-header">
    <h2>{c.agents.title}</h2>
    <p>{c.agents.subtitle}</p>
  </div>

  <div class="agents-grid">
    {
      ['OpenCode', 'VS Code / Copilot', 'Claude', 'Cursor', 'Windsurf', 'Cline', 'Continue', 'Codex', 'Gemini', 'Zed', 'Antigravity', 'Aider', 'KiloCode', 'OpenClaw', 'Kiro'].map((name, i) => {
        const icons = ['🤖', '🆚', '✳️', '🖱️', '🏄', '🧩', '⏯️', '⚡', '✨', '⚡', '🌌', '🤝', '⚖️', '🐾', '🪶'];
        return (
          <div class="agent-chip">
            <span class="agent-icon">{icons[i]}</span>
            <span class="agent-name">{name}</span>
          </div>
        );
      })
    }
  </div>
</section>

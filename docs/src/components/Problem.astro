---
import { getContent } from '../i18n';

interface Props {
	lang?: string;
}
const { lang = 'en' } = Astro.props;
const c = getContent(lang);
---

<section class="content-section problem-section">
  <div class="section-header">
    <h2>{c.problem.title}</h2>
    <p>{c.problem.subtitle}</p>
  </div>

  <div class="problem-grid">
    {
      c.problem.cards.map((p) => (
        <div class="problem-card">
          <div class="problem-icon">{p.icon}</div>
          <h3>{p.title}</h3>
          <p>{p.body}</p>
        </div>
      ))
    }
  </div>

  <p class="problem-resolution">{c.problem.resolution}</p>
</section>

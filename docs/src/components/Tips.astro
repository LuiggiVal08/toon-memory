---
import { getContent } from '../i18n';

interface Props {
	lang?: string;
}
const { lang = 'en' } = Astro.props;
const c = getContent(lang);
---

<section class="content-section">
  <div class="section-header">
    <h2>{c.tips.title}</h2>
    <p>{c.tips.subtitle}</p>
  </div>

  <div class="tip-grid">
    {
      c.tips.items.map((t) => (
        <div class="tip-card">
          <div class="tip-number">{t.n}</div>
          <h3 set:html={t.title}></h3>
          <p set:html={t.body}></p>
        </div>
      ))
    }
  </div>
</section>

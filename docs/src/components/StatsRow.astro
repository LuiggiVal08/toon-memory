---
import { getContent } from '../i18n';

interface Props {
	lang?: string;
}
const { lang = 'en' } = Astro.props;
const c = getContent(lang);
---

<div class="stats-row">
  {
    c.stats.items.map((s) => (
      <div class="stat-card">
        <span class="stat-number" data-count={s.number}>{s.number}</span>
        <span class="stat-label">{s.label}</span>
      </div>
    ))
  }
</div>

<script>
  import { animateCountsAndBars } from '../scripts/home-anim';
  const root = document.querySelector<HTMLElement>('.stats-row');
  if (root) animateCountsAndBars(root);
</script>

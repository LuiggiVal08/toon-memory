---
import { getContent } from '../i18n';

interface Props {
	lang?: string;
}
const { lang = 'en' } = Astro.props;
const c = getContent(lang);
---

<div class="stats-row">
  {
    c.stats.items.map((s) => (
      <div class="stat-card">
        <span class="stat-number">{s.number}</span>
        <span class="stat-label">{s.label}</span>
      </div>
    ))
  }
</div>

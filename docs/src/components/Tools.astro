---
import { getContent } from '../i18n';

interface Props {
	lang?: string;
}
const { lang = 'en' } = Astro.props;
const c = getContent(lang);

const resources = ['memory-entries', 'memory-stats', 'memory-summaries'];
---

<section class="content-section tools-section">
  <div class="section-header">
    <h2>{c.tools.title}</h2>
    <p>{c.tools.subtitle}</p>
  </div>

  <div class="tools-grid">
    {
      c.tools.cards.map((t) => (
        <div class="tool-card">
          <code class="tool-name">{t.name}</code>
          <h3 class="tool-title">{t.title}</h3>
          <p class="tool-desc">{t.desc}</p>
        </div>
      ))
    }
  </div>

  <div class="resources-row">
    <span class="resources-label">{c.tools.resourcesLabel}</span>
    {
      resources.map((r) => <code class="resource-pill">{r}</code>)
    }
  </div>
</section>

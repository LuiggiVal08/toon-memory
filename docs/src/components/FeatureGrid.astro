---
import { getContent } from '../i18n';

interface Props {
	lang?: string;
}
const { lang = 'en' } = Astro.props;
const c = getContent(lang);
---

<div class="feature-cards">
  {
    c.features.cards.map((f, i) => (
      <div class={`card${i === 0 ? ' featured' : ''}`}>
        <div class="card-icon">{f.icon}</div>
        <h3>{f.title}</h3>
        <p>{f.body}</p>
        {f.tags && (
          <div class="card-tags">
            {f.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
        )}
        {f.stats && (
          <div class="card-stats">
            {f.stats.map((s) => <span class="stat">{s}</span>)}
          </div>
        )}
      </div>
    ))
  }
</div>

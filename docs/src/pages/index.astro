---
import logoSrc from '../assets/logo.svg';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import MemoryGraphShowcase from '../components/MemoryGraphShowcase.astro';
import SmartRecallShowcase from '../components/SmartRecallShowcase.astro';
import ImpactShowcase from '../components/ImpactShowcase.astro';
import StatsRow from '../components/StatsRow.astro';
import Tips from '../components/Tips.astro';
import Comparison from '../components/Comparison.astro';
import CodeExamples from '../components/CodeExamples.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Agents from '../components/Agents.astro';
import Tools from '../components/Tools.astro';
import Benchmarks from '../components/Benchmarks.astro';
import Problem from '../components/Problem.astro';
import HowItWorks from '../components/HowItWorks.astro';
import TokenSavings from '../components/TokenSavings.astro';
import '../styles/home.css';

const description =
  'An MCP server giving AI coding agents offline, token-efficient memory — remember decisions, patterns, and bugs between sessions (68.5% fewer tokens than re-reading context).';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>toon-memory — Persistent memory for AI coding agents</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={logoSrc.src} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="toon-memory — Persistent memory for AI coding agents" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://luiggival08.github.io/toon-memory/" />
    <meta property="og:image" content="https://luiggival08.github.io/toon-memory/favicon.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="toon-memory" />
    <meta name="twitter:description" content={description} />
    <script is:inline>
      document.documentElement.classList.add('js');
      (function () {
        try {
          if (localStorage.getItem('toon-lang') === 'en') return;
          var langs = navigator.languages || [navigator.language || ''];
          var prefersEs = langs.some(function (l) {
            return String(l).toLowerCase().indexOf('es') === 0;
          });
          if (prefersEs) window.location.replace('/toon-memory/es');
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <SiteHeader />

    <main>
      <Hero />
		<Problem />
		<ImpactShowcase />
		<FeatureGrid />
		<MemoryGraphShowcase />
		<SmartRecallShowcase />
		<Agents />
      <StatsRow />
      <HowItWorks />
      <Tips />
      <Comparison />
      <CodeExamples />
      <TokenSavings />
      <Benchmarks />
      <Tools />
      <FAQ />
      <CTA />
    </main>

    <SiteFooter />
  </body>
</html>

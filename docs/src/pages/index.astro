---
import logoSrc from '../assets/logo.svg';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import StatsRow from '../components/StatsRow.astro';
import Tips from '../components/Tips.astro';
import Comparison from '../components/Comparison.astro';
import CodeExamples from '../components/CodeExamples.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import SiteFooter from '../components/SiteFooter.astro';

const description =
  'Persistent memory for AI coding agents. Remember decisions, patterns, and bugs between sessions.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>toon-memory — Persistent memory for AI coding agents</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={logoSrc.src} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="toon-memory — Persistent memory for AI coding agents" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://luiggival08.github.io/toon-memory/" />
    <meta property="og:image" content="https://luiggival08.github.io/toon-memory/favicon.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="toon-memory" />
    <meta name="twitter:description" content={description} />
  </head>
  <body>
    <SiteHeader />

    <main>
      <Hero />

      <div class="badges-row">
        <a href="https://www.npmjs.com/package/toon-memory">
          <img src="https://img.shields.io/npm/v/toon-memory.svg" alt="npm version" />
        </a>
        <a href="https://github.com/LuiggiVal08/toon-memory/blob/main/LICENSE">
          <img src="https://img.shields.io/badge/License-MIT-yellow.svg" alt="License: MIT" />
        </a>
        <a href="https://github.com/LuiggiVal08/toon-memory/actions">
          <img src="https://github.com/LuiggiVal08/toon-memory/actions/workflows/ci.yml/badge.svg" alt="CI" />
        </a>
        <a href="https://github.com/LuiggiVal08/toon-memory/stargazers">
          <img src="https://img.shields.io/github/stars/LuiggiVal08/toon-memory?style=social" alt="GitHub stars" />
        </a>
      </div>

      <FeatureGrid />
      <StatsRow />
      <Tips />
      <Comparison />
      <CodeExamples />
      <FAQ />
      <CTA />
    </main>

    <SiteFooter />

    <style is:global>
      :root {
        --brand: #6366f1;
        --brand-light: #818cf8;
        --brand-dark: #4f46e5;
        --brand-glow: rgba(99, 102, 241, 0.5);
        --gradient: linear-gradient(135deg, #6366f1, #8b5cf6, #a855f7);
        --bg: #0f0f13;
        --bg-card: #1a1a24;
        --border: #2a2a3a;
        --text: #e2e2e8;
        --text-muted: #8888a0;
        --font-mono: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      a { color: var(--brand-light); text-decoration: none; }
      a:hover { text-decoration: underline; }

      /* Header */
      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 2rem;
        border-bottom: 1px solid var(--border);
      }
      .site-logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 700;
        font-size: 1.2rem;
        color: var(--text);
      }
      .logo-icon { width: 28px; height: 28px; }
      .site-nav { display: flex; gap: 1.5rem; }
      .site-nav a { color: var(--text-muted); font-size: 0.95rem; }
      .site-nav a:hover { color: var(--text); text-decoration: none; }

      /* Hero */
      .hero {
        position: relative;
        padding: 4rem 2rem;
        overflow: hidden;
      }

      .hero::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(ellipse at center, rgba(99,102,241,0.2) 0%, transparent 70%);
        animation: heroGlow 6s ease-in-out infinite;
        pointer-events: none;
      }

      .hero::after {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background:
          radial-gradient(circle at 20% 80%, rgba(99,102,241,0.3) 0%, transparent 50%),
          radial-gradient(circle at 80% 20%, rgba(139,92,246,0.3) 0%, transparent 50%),
          radial-gradient(circle at 40% 40%, rgba(168,85,247,0.2) 0%, transparent 50%);
        animation: heroGradient 8s ease-in-out infinite;
        pointer-events: none;
      }

      .hero-split {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4rem;
        max-width: 1000px;
        margin: 0 auto;
      }

      .hero-visual {
        flex: 0 0 auto;
        display: flex;
        justify-content: center;
        order: 1;
      }

      .hero-text {
        flex: 1;
        max-width: 480px;
      }

      .hero-logo {
        display: inline-block;
        animation: float 3s ease-in-out infinite;
      }
      .hero-logo::after {
        content: '';
        display: block;
        margin: 0 auto;
        margin-top: -8px;
        width: 80%;
        height: 6px;
        background: var(--gradient);
        border-radius: 3px;
        animation: pulse 2s ease-in-out infinite;
      }
      .hero-logo-img {
        width: 310px;
        height: 310px;
        filter: drop-shadow(0 20px 40px var(--brand-glow));
      }

      .hero-text {
        flex: 1;
        max-width: 480px;
      }

      .hero-title {
        font-size: 3rem;
        font-weight: 800;
        background: var(--gradient);
        background-size: 200% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: heroTitleIn 1s cubic-bezier(0.16,1,0.3,1), gradientShift 3s linear infinite;
        letter-spacing: -0.02em;
        margin-bottom: 0.5rem;
      }

      @keyframes heroTitleIn {
        from { opacity: 0; transform: translateY(40px) scale(0.95); filter: blur(10px); }
        to { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
      }
      @keyframes gradientShift {
        0% { background-position: 0% center; }
        100% { background-position: 200% center; }
      }

      .hero-tagline {
        animation: heroTaglineIn 1s cubic-bezier(0.16,1,0.3,1) 0.2s both;
        font-size: 1.2rem;
        color: var(--text);
        margin-bottom: 0.25rem;
      }

      @keyframes heroTaglineIn {
        from { opacity: 0; transform: translateY(30px); filter: blur(5px); }
        to { opacity: 1; transform: translateY(0); filter: blur(0); }
      }

      .hero-subtitle {
        font-size: 1rem;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
      }

      .hero-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .btn-install {
        margin-top: 0.75rem;
      }

      /* Particles */
      .particles {
        position: absolute;
        top: 0; left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        overflow: hidden;
        z-index: 0;
      }
      .particle {
        position: absolute;
        width: 8px;
        height: 8px;
        background: var(--brand);
        border-radius: 50%;
        opacity: 0;
        animation: particleFloat 12s linear infinite;
        box-shadow: 0 0 20px var(--brand-glow);
      }
      .particle:nth-child(1) { left: 10%; animation-delay: 0s; }
      .particle:nth-child(2) { left: 20%; animation-delay: 1.5s; }
      .particle:nth-child(3) { left: 30%; animation-delay: 3s; }
      .particle:nth-child(4) { left: 40%; animation-delay: 4.5s; }
      .particle:nth-child(5) { left: 50%; animation-delay: 6s; }
      .particle:nth-child(6) { left: 60%; animation-delay: 7.5s; }
      .particle:nth-child(7) { left: 70%; animation-delay: 9s; }
      .particle:nth-child(8) { left: 80%; animation-delay: 10.5s; }
      .particle:nth-child(9) { left: 15%; animation-delay: 2s; }
      .particle:nth-child(10) { left: 85%; animation-delay: 5s; }

      @keyframes particleFloat {
        0% { transform: translateY(100vh) scale(0) rotate(0deg); opacity: 0; }
        10% { opacity: 0.8; }
        90% { opacity: 0.8; }
        100% { transform: translateY(-100vh) scale(1.5) rotate(720deg); opacity: 0; }
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: 9999px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all 0.2s;
        text-decoration: none;
      }
      .btn .icon { flex-shrink: 0; }
      .btn-primary {
        background: var(--gradient);
        color: #fff;
        border-color: transparent;
      }
      .btn-primary:hover {
        box-shadow: 0 0 20px var(--brand-glow);
        transform: translateY(-2px);
        text-decoration: none;
      }

      .btn-github {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.75rem 0;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        border: none;
        background: none;
        color: var(--text);
        text-decoration: none;
        transition: color 0.2s;
      }
      .btn-github:hover {
        color: var(--brand-light);
        text-decoration: none;
      }
      .btn-github .external-icon {
        transition: opacity 0.2s;
      }
      .btn-github:hover .external-icon {
        opacity: 0.8;
      }
      .btn-install {
        background: var(--bg-card);
        color: var(--text);
        border-color: var(--border);
        font-family: var(--font-mono);
        font-size: 0.9rem;
      }
      .btn-install:hover {
        border-color: var(--brand);
        box-shadow: 0 0 20px var(--brand-glow);
        transform: translateY(-2px);
      }
      .install-prompt { opacity: 0.5; margin-right: 0.25rem; }
      .install-copy, .install-done { font-family: inherit; }
      .install-done { display: none; color: #22c55e; }
      .btn-install.copied .install-copy { display: none; }
      .btn-install.copied .install-done { display: inline; }
      .install-cmd { margin-right: 0.5rem; }

      /* Badges */
      .badges-row {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        padding: 0 2rem 2rem;
        flex-wrap: wrap;
      }
      .badges-row img { height: 20px; }

      /* Feature cards */
      .feature-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
        padding: 0 2rem 3rem;
        max-width: 720px;
        margin: 0 auto;
      }
      .card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.5rem;
        text-align: left;
        transition: transform 0.2s, border-color 0.2s;
        position: relative;
        overflow: hidden;
      }
      .card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--gradient);
        opacity: 0;
        transition: opacity 0.2s;
      }
      .card:hover::before { opacity: 1; }
      .card:hover {
        transform: translateY(-4px);
        border-color: var(--brand);
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
      }
      .card-icon { font-size: 1.75rem; margin-bottom: 0.75rem; }
      .card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
      .card p { color: var(--text-muted); font-size: 0.85rem; line-height: 1.6; }

      .card-tags, .card-stats {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 0.75rem;
      }
      .tag {
        font-size: 0.7rem;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        background: rgba(99,102,241,0.12);
        color: var(--brand-light);
        font-family: var(--font-mono);
        font-weight: 500;
        letter-spacing: 0.01em;
      }
      .stat {
        font-size: 0.7rem;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        background: rgba(34,197,94,0.1);
        color: #22c55e;
        font-family: var(--font-mono);
        font-weight: 500;
      }

      /* Stats */
      .stats-row {
        display: flex;
        justify-content: center;
        gap: 2rem;
        padding: 0 2rem 3rem;
        flex-wrap: wrap;
      }
      .stat-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
      }
      .stat-number {
        font-size: 2.5rem;
        font-weight: 800;
        background: var(--gradient);
        background-size: 200% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: gradientShift 3s linear infinite;
        line-height: 1;
      }
      .stat-label {
        font-size: 0.8rem;
        color: var(--text-muted);
        font-weight: 500;
      }

      /* Content */
      .content-section {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 2rem 4rem;
      }
      .section-header {
        margin: 3rem 0 1.5rem;
      }
      .section-header h2 {
        font-size: 1.75rem;
        background: var(--gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 0.5rem;
      }
      .section-header p {
        color: var(--text-muted);
        font-size: 0.95rem;
      }

      /* Tip cards */
      .tip-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }
      .tip-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.25rem;
        position: relative;
        transition: border-color 0.2s, transform 0.2s;
      }
      .tip-card:hover {
        border-color: var(--brand);
        transform: translateY(-2px);
      }
      .tip-number {
        font-size: 1.5rem;
        font-weight: 800;
        color: rgba(99,102,241,0.25);
        line-height: 1;
        margin-bottom: 0.5rem;
      }
      .tip-card h3 {
        font-size: 1rem;
        margin-bottom: 0.4rem;
      }
      .tip-card p {
        color: var(--text-muted);
        font-size: 0.85rem;
        line-height: 1.6;
      }
      .inline-code {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        padding: 0.1em 0.3em;
        background: rgba(99,102,241,0.1);
        border-radius: 3px;
        color: var(--brand-light);
      }

      /* Comparison */
      .comparison {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
      }
      .compare-box {
        border-radius: 12px;
        padding: 1.5rem;
        border: 1px solid var(--border);
        transition: transform 0.2s;
      }
      .compare-box:hover { transform: translateY(-2px); }
      .compare-box.before {
        background: rgba(239,68,68,0.06);
        border-color: rgba(239,68,68,0.25);
      }
      .compare-box.after {
        background: rgba(34,197,94,0.06);
        border-color: rgba(34,197,94,0.25);
      }
      .compare-box h3 { font-size: 1.1rem; margin-bottom: 0.75rem; }
      .compare-box.before h3 { color: #ef4444; }
      .compare-box.after h3 { color: #22c55e; }
      .compare-box ul { list-style: none; padding: 0; }
      .compare-box li {
        padding: 0.35rem 0;
        color: var(--text-muted);
        font-size: 0.85rem;
        position: relative;
        padding-left: 1.25rem;
      }
      .compare-box li::before {
        content: '✗';
        position: absolute;
        left: 0;
        color: #ef4444;
        opacity: 0.7;
      }
      .compare-box.after li::before {
        content: '✓';
        color: #22c55e;
      }

      pre {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.25rem;
        overflow-x: auto;
        margin: 1rem 0;
      }
      pre code {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        line-height: 1.6;
        color: var(--text);
      }

      /* Footer */
      .site-footer {
        border-top: 1px solid var(--border);
        padding: 2rem;
        text-align: center;
        color: var(--text-muted);
        font-size: 0.9rem;
        margin-top: auto;
      }
      .site-footer a { color: var(--text-muted); }

      /* FAQ */
      .faq-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }
      .faq-item {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
      }
      .faq-item summary {
        cursor: pointer;
        padding: 1rem 1.25rem;
        font-weight: 600;
        list-style: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .faq-item summary::-webkit-details-marker { display: none; }
      .faq-item summary::after {
        content: '+';
        color: var(--brand-light);
        font-size: 1.25rem;
      }
      .faq-item[open] summary::after { content: '−'; }
      .faq-item p {
        padding: 0 1.25rem 1.25rem;
        color: var(--text-muted);
        font-size: 0.9rem;
        line-height: 1.6;
      }

      /* CTA */
      .cta-section {
        padding-bottom: 5rem;
        padding-top: 1rem;
      }
      .cta-box {
        background: linear-gradient(135deg, rgba(99,102,241,0.15), rgba(168,85,247,0.15));
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 2.5rem 1.5rem;
        text-align: center;
      }
      .cta-box h2 {
        font-size: 1.75rem;
        background: var(--gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 0.5rem;
      }
      .cta-box p {
        color: var(--text-muted);
        margin-bottom: 1.5rem;
      }
      .cta-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
      }

      @media (max-width: 768px) {
        .hero-split { flex-direction: column; gap: 2rem; text-align: center; }
        .hero-actions { justify-content: center; }
        .hero-logo-img { width: 200px; height: 200px; }
        .hero-title { font-size: 2.5rem; }
        .hero { padding: 3rem 1rem 2rem; }
        .site-header { padding: 0.75rem 1rem; }
        .feature-cards { grid-template-columns: 1fr; }
        .tip-grid { grid-template-columns: 1fr; }
        .comparison { grid-template-columns: 1fr; }
        .stats-row { gap: 1.5rem; }
        .stat-number { font-size: 2rem; }
      }
      @media (max-width: 600px) {
        .hero-actions { flex-direction: column; align-items: stretch; }
        .btn-install { width: 100%; justify-content: center; }
      }
    </style>
  </body>
</html>
